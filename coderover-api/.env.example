# App
PORT=3001
NODE_ENV=development
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=change-me

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=coderover
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# OpenAI
OPENAI_API_KEY=sk-ant-...
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
OPENAI_EMBEDDING_DIMENSIONS=1536
LLM_PROVIDER=local
# Set to false on dev boxes that don't run a local LLM — skips the health
# probe so /health reports `llm.status: disabled` instead of `down`.
# Also auto-disables when LLM_PROVIDER=local with no OPENAI_BASE_URL and no
# OPENAI_API_KEY set. Default: true.
LLM_HEALTH_CHECK_ENABLED=true

# Anthropic (for PR review - Day 6)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback
FRONTEND_APP_URL=http://localhost:5173

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Settings encryption (AES-256-GCM master key for SystemSetting secrets).
# Required in production for encrypting OPENAI_API_KEY, GITHUB_TOKEN, etc.
# at rest in the DB. Generate with: openssl rand -base64 32
# Dev/CI may leave blank if no secret rows are touched (CryptoService
# throws a clear error on first encrypt/decrypt call when unset).
SETTINGS_ENCRYPTION_KEY=

# Ingestion defaults
FILE_WATCH_ENABLED=true

# Memgraph (graph database for code dependency analysis)
MEMGRAPH_URI=bolt://localhost:7687

# Agent system
AGENT_PR_ENABLED=false
AGENT_SCAN_ON_PUSH=false
AGENT_HEALTH_CRON=
AGENT_MAX_RUNS_PER_HOUR=3

# GitHub App (optional, for PR review check_run integration)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Public URL for webhook registration (used by GitHub integration)
PUBLIC_API_BASE_URL=http://localhost:3001
