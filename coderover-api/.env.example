# App
PORT=3001
NODE_ENV=development
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=change-me

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=coderover
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Phase 5 (Zero Trust): dedicated DDL user. After running
# `coderover-api/sql/bootstrap-roles.sql` (see docs/runbook-db-roles.md),
# set DATABASE_USER to the lower-privileged runtime role
# (`coderover_app` — CRUD only, no DDL) and these to the migrate role
# (`coderover_migrate` — DDL only, used at deploy time).
#
# Both optional. When either is unset, migrations run as DATABASE_USER —
# matches pre-Phase-5 behavior, fine for dev with the seeded
# `postgres` superuser.
DATABASE_MIGRATE_USER=
DATABASE_MIGRATE_PASSWORD=

# Phase 5 (compose-only): passwords the postgres init script uses to
# create the coderover_app + coderover_migrate roles on FIRST `docker
# compose up` of a fresh pgdata volume. Generate with
# `openssl rand -base64 32`. Ignored on non-compose deploys; production
# operators run the bootstrap SQL out-of-band.
CODEROVER_APP_PASSWORD=
CODEROVER_MIGRATE_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# OpenAI
OPENAI_API_KEY=sk-ant-...
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
OPENAI_EMBEDDING_DIMENSIONS=1536
LLM_PROVIDER=local
# Set to false on dev boxes that don't run a local LLM — skips the health
# probe so /health reports `llm.status: disabled` instead of `down`.
# Also auto-disables when LLM_PROVIDER=local with no OPENAI_BASE_URL and no
# OPENAI_API_KEY set. Default: true.
LLM_HEALTH_CHECK_ENABLED=true

# Phase 4A: LLM kill switch (Zero Trust emergency stop).
# When set to a truthy value (1, true, yes, on, enabled), every outbound
# LLM call site that has been wired through LLMKillSwitchService will
# refuse the request and return HTTP 503 with a clear operator message.
# Use this when:
#   - the LLM provider is suspected of returning tampered output
#   - a prompt-injection / data-exfiltration incident is being
#     investigated
#   - cost emergency: stop spend on every LLM call until further notice
# Re-read on every call (no caching), so flipping in a running container
# (where the orchestrator supports env reload) takes effect instantly.
# Default: unset = OFF.
LLM_KILL_SWITCH=

# Phase 4C: LLM anomaly alerts. The api runs a periodic sweep over the
# `llm_audit_log` table and emits structured warn-level log lines when
# any signal breaches its threshold. Tune the thresholds per environment
# — staging baselines are noticeably lower than prod.
#
# Set any threshold to 0 to disable that signal. Set the interval to 0
# to disable the sweep entirely.
ANOMALY_CHECK_INTERVAL_MS=300000        # how often to sweep (5min)
ANOMALY_WINDOW_MINUTES=60               # look-back window for each query
ANOMALY_TOKEN_RATE_PER_ORG=100000       # alert if any org exceeds this token total in the window
ANOMALY_REDACTIONS_PER_CALL_SITE=10     # alert if a call_site has >= N rows with redactions in the window
ANOMALY_KILL_SWITCH_BLOCKS=50           # alert if global kill-switch-block count >= N in the window

# Anthropic (for PR review - Day 6)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback
FRONTEND_APP_URL=http://localhost:5173

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Settings encryption (AES-256-GCM master key).
# Required in production. Used to encrypt at rest:
#   1. SystemSetting secret rows (OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.)
#      via CryptoService — jsonb envelope.
#   2. GitHub OAuth + PAT tokens in the `github_connections.access_token`,
#      `github_connections.refresh_token`, and `repos.github_token` columns
#      via the `encryptedString` TypeORM transformer — text envelope.
# Same key for both paths so rotation is one operation.
# Generate with: openssl rand -base64 32
# Dev/CI may leave blank if no secret rows or token columns are touched —
# the transformer throws a clear error on first encrypt/decrypt if unset.
# WARNING: losing this key = losing every secret + token in the DB. There
# is no recovery path. Store it in a secrets manager, not in source.
SETTINGS_ENCRYPTION_KEY=

# Ingestion defaults
FILE_WATCH_ENABLED=true

# Memgraph (graph database for code dependency analysis)
MEMGRAPH_URI=bolt://localhost:7687

# Agent system
AGENT_PR_ENABLED=false
AGENT_SCAN_ON_PUSH=false
AGENT_HEALTH_CRON=
AGENT_MAX_RUNS_PER_HOUR=3

# GitHub App — RECOMMENDED auth path for repo operations (Phase 2B).
# When configured, GitHubTokenResolver prefers App installation tokens over
# the user's OAuth token for any repo whose owner has the App installed.
# Installation tokens are short-lived (~1h), per-install scoped, and do not
# require the broad `repo` OAuth scope.
#
# One-time setup per environment:
#   1. Create the App at:
#        github.com/organizations/<org>/settings/apps/new
#      (or in personal user settings for a per-user App).
#   2. Permissions:
#        Repository → Contents (read)
#        Repository → Pull requests (read + write — for PR-review posting)
#        Repository → Checks (write — for check-run integration)
#   3. Save, then download the private key (.pem) from the App page.
#   4. Paste the PEM body below. Multi-line $'...' export, or replace
#      newlines with \n inline; ConfigService accepts either.
#   5. Install the App on each org/account whose repos CodeRover should
#      access. The resolver auto-discovers installs via the App API and
#      caches the lookup for 5 min.
#
# Leave blank to fall back to OAuth-only (pre-Phase-2B behavior).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Public URL for webhook registration (used by GitHub integration)
PUBLIC_API_BASE_URL=http://localhost:3001
